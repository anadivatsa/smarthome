ANTHROPIC_API_KEY=

# Claude model — default is claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# Whisper model size: tiny / base / small / medium
# base (~75 MB) is the recommended default on Pi 4
WHISPER_MODEL=base

# WebRTC VAD aggressiveness: 0 (least) – 3 (most)
# 2 works well indoors; bump to 3 in noisy environments
VAD_MODE=2

# Seconds of silence that mark the end of an utterance
SILENCE_TIMEOUT=0.9

# Minimum utterance length — shorter clips are dropped
MIN_SPEECH_SEC=0.4

# Hub URL — leave as default unless you change HUB_PORT
HUB_URL=http://localhost:5001
