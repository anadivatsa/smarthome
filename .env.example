# Neo Smart Home Hub — environment variable reference
# Copy the relevant sections into the appropriate *.env files and fill in values.
# Never commit files without the .example suffix.

# ── hub.env ────────────────────────────────────────────────────────────────
# API key protecting all hub endpoints. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NEO_API_KEY=

# Network / service config (defaults shown — only set if you need to override)
HUB_PORT=5001
HUB_IP=192.168.1.8
LAMP_URL=http://localhost:5000
TV_IP=192.168.1.2
TV_MAC=
TV_PORT=8002

# ── voice.env ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
WHISPER_MODEL=base
VAD_MODE=2
SILENCE_TIMEOUT=0.9
MIN_SPEECH_SEC=0.4
HUB_URL=http://localhost:5001
INPUT_DEVICE=

# ── notifier.env ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── spotify.env ────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://192.168.1.8:5001/spotify/callback

# ── wiz-lamp/config.env ────────────────────────────────────────────────────
LAMP_IP=192.168.1.9
PORT=5000
