[Unit]
Description=Smart Home Hub
After=network-online.target wiz-lamp.service
Wants=network-online.target

[Service]
Type=simple
User=anadivatsa
WorkingDirectory=/home/anadivatsa/smarthome
ExecStart=/home/anadivatsa/smarthome/venv/bin/python hub.py
Restart=on-failure
RestartSec=5
EnvironmentFile=-/home/anadivatsa/smarthome/hub.env
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1
Environment=TV_IP=192.168.1.2

[Install]
WantedBy=multi-user.target
